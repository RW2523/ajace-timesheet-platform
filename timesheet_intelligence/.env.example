# ============================================================================
# Timesheet Intelligence Core Engine -- environment configuration
# Copy to `.env` and fill in. Every value is optional: with no API key the
# engine runs the deterministic + local-OCR pipeline and flags anything that
# would benefit from an LLM. Provide a key to unlock vision/LLM normalization.
# ============================================================================

# ---- OpenRouter (ALL LLM/vision calls go through OpenRouter) ----
TSE_OPENROUTER_API_KEY=
TSE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers recommended by OpenRouter
TSE_OPENROUTER_APP_TITLE=Timesheet Intelligence
TSE_OPENROUTER_REFERER=https://timesheet-intelligence.local

# ---- Model routing (override any single task; see config/models.yaml) ----
# Leave blank to use config/models.yaml defaults.
TSE_MODEL_CLASSIFY=
TSE_MODEL_VISION=
TSE_MODEL_TABLE=
TSE_MODEL_NORMALIZE=
TSE_MODEL_VALIDATE=

# ---- Behaviour ----
# never | on_low_confidence | always  -- when to invoke the LLM layer
TSE_LLM_POLICY=on_low_confidence
# Confidence below which deterministic results are escalated to the LLM
TSE_LLM_CONFIDENCE_THRESHOLD=0.6
# Use local tesseract OCR as a fallback when no vision model is configured
TSE_USE_LOCAL_OCR=true
TSE_TESSERACT_CMD=tesseract
TSE_OCR_DPI=220
# Opt-in IBM Docling (TableFormer) fallback table extractor (default off)
TSE_USE_DOCLING=false

# ---- Calendar / policy (Phase-1 display only; rules deferred to later phases) ----
# ISO country code used to pick the built-in holiday set (US supported; others -> none)
TSE_HOLIDAY_REGION=US
# Comma-separated extra holiday dates (YYYY-MM-DD) appended to the built-in set
TSE_EXTRA_HOLIDAYS=
# Weekend weekdays (0=Mon .. 6=Sun)
TSE_WEEKEND_DAYS=5,6
# Sanity bound: a single day above this many hours is flagged
TSE_MAX_HOURS_PER_DAY=16

# ---- Paths ----
TSE_OUTPUT_DIR=output
