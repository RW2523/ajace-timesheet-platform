# Supabase project (Project Settings → API). The anon/publishable key is safe to
# expose to the browser; access is protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt

# Base URL of the Python AI engine (FastAPI) that processes uploaded timesheets
ENGINE_URL=http://127.0.0.1:8078
